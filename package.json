{
    "name": "agent-visualizer",
    "displayName": "Agent Visualizer",
    "description": "Visualize Cursor AI agent work: conversation timelines, tool usage analytics, agent hierarchy trees, and reasoning flow diagrams",
    "version": "0.1.0",
    "publisher": "agent-visualizer",
    "repository": {
        "type": "git",
        "url": "https://github.com/mozammal-hossain/agent-visualizer.git"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Visualization",
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "agent-visualizer",
                    "title": "Agent Visualizer",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "agent-visualizer": [
                {
                    "id": "agentSessions",
                    "name": "Sessions",
                    "when": "true"
                }
            ],
            "explorer": [
                {
                    "id": "agentSessions",
                    "name": "Agent Visualizer Sessions",
                    "when": "true"
                }
            ]
        },
        "commands": [
            {
                "command": "agent-visualizer.openSession",
                "title": "Open Session",
                "category": "Agent Visualizer"
            },
            {
                "command": "agent-visualizer.refresh",
                "title": "Refresh Sessions",
                "category": "Agent Visualizer",
                "icon": "$(refresh)"
            },
            {
                "command": "agent-visualizer.copySessionId",
                "title": "Copy Session ID",
                "category": "Agent Visualizer"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "agent-visualizer.refresh",
                    "group": "navigation",
                    "when": "view == agentSessions"
                }
            ],
            "view/item/context": [
                {
                    "command": "agent-visualizer.openSession",
                    "group": "inline",
                    "when": "view == agentSessions && viewItem =~ /session/"
                },
                {
                    "command": "agent-visualizer.copySessionId",
                    "group": "1_modification",
                    "when": "view == agentSessions && viewItem =~ /session/"
                }
            ]
        }
    },
    "scripts": {
        "postinstall": "cd webview-ui && npm install",
        "vscode:prepublish": "npm run build",
        "build": "npm run build:ext && npm run build:webview",
        "build:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node18",
        "build:webview": "cd webview-ui && vite build",
        "watch": "npm run watch:ext & npm run watch:webview",
        "watch:ext": "npm run build:ext -- --watch",
        "watch:webview": "cd webview-ui && vite build --watch",
        "dev": "npm run watch",
        "test": "vitest",
        "lint": "eslint src webview-ui/src",
        "package": "npm run build && npx vsce package --no-dependencies"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.2.0",
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.85.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "esbuild": "^0.19.0",
        "eslint": "^8.0.0",
        "typescript": "^5.3.0",
        "vite": "^5.0.0"
    },
    "dependencies": {
        "vscode-webview": "^1.0.0"
    }
}